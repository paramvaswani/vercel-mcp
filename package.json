{
  "name": "vercel-mcp-server",
  "version": "0.1.0",
  "description": "MCP server for the Vercel REST API. Deployments, projects, domains, env vars, build logs.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "vercel-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "smoke": "tsx scripts/smoke-test.ts",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
